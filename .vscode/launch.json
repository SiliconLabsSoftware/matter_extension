  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug",
      "type": "cortex-debug",
      "cwd": "${workspaceFolder}",
      "request": "attach",
      "servertype": "jlink",
      "serverpath": "/usr/local/bin/JLinkGDBServer",
      "armToolchainPath": "/Users/svc_matter/.silabs/slt/installs/conan/p/gcc-af360b79bab9e3/p/bin/",
      "showDevDebugOutput": "vscode",
      "runToEntryPoint": "main",
