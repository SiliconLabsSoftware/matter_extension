      // BRD4338A
      "executable": "${workspaceFolder}/out/brd4338a/lighting-app-siwx-solution/lighting-app-siwx/build/debug/lighting-app-siwx.out",
      "device": "${input:device}",
      "serialNumber": ""
    }
