{
    "standard": {
        "default": [
            {
                "boards": ["brd2709a"],
                "arguments": [""]
            },
            {
                "boards": ["brd2709a"],
                "arguments": ["--output_suffix copy-sources", "--copy-sources"]
            }
        ]
    },
    "full": {

        "default": [
            {
                "boards": ["brd2709a"],
                "arguments": [""]
            },
            {
                "boards": ["brd2709a"],
                "arguments": ["--output_suffix copy-sources", "--copy-sources"]
            }
        ],
        "zigbee_light":  [
            {
                "boards": ["brd2709a"],
                "arguments": ["--output_suffix sequential","--with_app matter_zigbee_sequential"] 
            },
            {
                "boards": ["brd2709a"],
                "arguments": ["--output_suffix sequential-copy-sources","--with_app matter_zigbee_sequential", "--copy-sources"] 
            }
        ],
        "platform_template": [
            {
                "boards": ["brd2709a"],
                "arguments": ["--output_suffix peripherals","--with_app matter_peripherals"] 
            },
            {
                "boards": ["brd2709a"],
                "arguments": ["--output_suffix peripherals-icd","--with_app matter_peripherals,matter_icd_core"] 
            },
            {
                "boards": ["brd2709a"],
                "arguments": ["--output_suffix peripherals-icd-copy-sources","--with_app matter_peripherals,matter_icd_core", "--without_app matter_log_rtt", "--copy-sources"] 
            }
        ]
    },
    "custom-sqa": {
        "zigbee_light": [
            {
                "boards": ["brd2709a"],
                "arguments": ["--output_suffix cmp-concurrent-ota-2", "-pids application", "--with_app matter_zigbee_concurrent",
                              "'--configuration CHIP_DEVICE_CONFIG_DEVICE_SOFTWARE_VERSION:2,CHIP_DEVICE_CONFIG_DEVICE_SOFTWARE_VERSION_STRING:\"2\"'"]
            }
        ],
        "lock_app" :[
            {
                "boards": ["brd4116a"],
                "arguments": ["--output_suffix low-power",
                              "--with_app matter_platform_low_power",
                              "--without_app matter_shell,matter_qr_code,matter_lcd,matter_thread_cli,matter_default_lcd_config,matter_uart,matter_log_uart"]
            }
        ],
        "light_switch_app": [
            {
                "boards": ["brd4116a"],
                "arguments": ["--output_suffix low-power",
                              "--with_app matter_platform_low_power",
                              "--without_app matter_shell,matter_qr_code,matter_lcd,matter_thread_cli,matter_default_lcd_config,matter_uart,matter_log_uart"]
            }
        ],
        "multi_sensor_app": [
            {
                "boards": ["brd4116a"],
                "arguments": ["--output_suffix low-power",
                              "--with_app matter_platform_low_power",
                              "--without_app matter_shell,matter_qr_code,matter_lcd,matter_thread_cli,matter_default_lcd_config,matter_uart,matter_log_uart"]
            }
        ],
        "window_app": [
            {
                "boards": ["brd4116a"],
                "arguments": ["--output_suffix low-power",
                              "--with_app matter_platform_low_power",
                              "--without_app matter_shell,matter_qr_code,matter_lcd,matter_thread_cli,matter_default_lcd_config,matter_uart,matter_log_uart"]
            }
        ],
        "closure_app": [
            {
                "boards": ["brd4116a"],
                "arguments": ["--output_suffix low-power",
                              "--with_app matter_platform_low_power",
                              "--without_app matter_shell,matter_qr_code,matter_lcd,matter_thread_cli,matter_default_lcd_config,matter_uart,matter_log_uart"]
            }
        ]
    }
