#!/usr/bin/env python3
"""Customer-facing entry point shipped in the matter Conan package."""

from __future__ import annotations

import sys
from pathlib import Path

_SCRIPT_DIR = Path(__file__).resolve().parent
if (_SCRIPT_DIR / "matter_slconf").is_dir():
    _PYTHON_ROOT = _SCRIPT_DIR
elif _SCRIPT_DIR.name == "bin":
    _PYTHON_ROOT = _SCRIPT_DIR.parent / "python"
else:
    _PYTHON_ROOT = _SCRIPT_DIR

if str(_PYTHON_ROOT) not in sys.path:
    sys.path.insert(0, str(_PYTHON_ROOT))

from matter_slconf.cli import main  # noqa: E402

if __name__ == "__main__":
    # Default subcommand for: matter-app-slconf <app_dir> [--slcp-name NAME]
    if len(sys.argv) > 1 and sys.argv[1] not in (
        "slconf",
        "validate-slcp",
        "build-app",
        "-h",
        "--help",
    ):
        sys.argv = [sys.argv[0], "slconf", *sys.argv[1:]]
    raise SystemExit(main())
