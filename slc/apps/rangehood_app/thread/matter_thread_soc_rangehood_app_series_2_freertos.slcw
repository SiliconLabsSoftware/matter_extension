workspace_name: matter_thread_soc_rangehood_app_series_2_freertos
label: Matter Thread - SoC Rangehood with external Bootloader FreeRTOS
quality: production
package: matter
description: Demonstrates a sample implementation of a Matter over Thread rangehood app with external bootloader
project:
  - path: ./matter_thread_soc_rangehood_app_freertos.slcp
    id: application
    output: rangehood_app
  - path: ../../bootloaders/bootloader_storage_external_single_series_2/matter_bootloader_external_series_2.slcp
    id: bootloader
    output: matter_bootloader
post_build:
  path: ../../../postbuild/ws_default_application_bootloader.slpb
