label: thermostat-app-thread-bootloader
quality: production
package: matter
description: Matter solution containing both a Matter bootloader and Thermostat over Thread Example
project:
  - path: ./thermostat-app.slcp
    id: application
    output: thermostat-app-thread
  - path: ../../bootloaders/bootloader-storage-single-4096k-series-3/bootloader-storage-single-4096k-series-3.slcp
    id: bootloader
    output: matter-bootloader
post_build:
  path: ../../../postbuild/ws_default_application_bootloader.slpb
