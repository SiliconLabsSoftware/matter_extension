label: performance-test-app-thread-bootloader
quality: production
package: matter
description: Matter solution containing both a Matter bootloader and Performance Test over Thread Example
project:
  - path: ./performance-test-app.slcp
    id: application
    output: performance-test-app-thread
  - path: ../../bootloaders/bootloader-storage-external-single-series-2/bootloader-storage-external-single-series-2.slcp
    id: bootloader
    output: matter-bootloader
post_build:
  path: ../../../postbuild/ws_default_application_bootloader.slpb
