workspace_name: matter_thread_soc_performance_test_app_series_3_freertos
label: Matter Thread - SoC Performance Test with internal Bootloader FreeRTOS
quality: internal
package: matter
description: Demonstrates a sample implementation of a Matter over Thread performance test app with internal bootloader
project:
  - path: ./matter_thread_soc_performance_test_app_freertos.slcp
    id: application
    output: performance_test_app
  - path: ../../bootloaders/bootloader_storage_single_4096k_series_3/matter_bootloader_internal_series_3.slcp
    id: bootloader
    output: matter_bootloader
post_build:
  path: ../../../postbuild/ws_default_application_bootloader.slpb
