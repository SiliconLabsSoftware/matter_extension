workspace_name: matter_wifi_917_ncp_lock_app_freertos_dual_stack
label: Matter WiFi - 917 NCP Lock FreeRTOS (dual stack)
quality: production
package: matter
description: Matter solution with Matter bootloader and Lock WiFi (917 NCP dual stack)
project:
  - path: ./matter_wifi_917_ncp_lock_app_freertos_dual_stack.slcp
    id: application
    output: lock-app-917-ncp-dual-stack
  - path: ../../bootloaders/bootloader_storage_internal_single_series_2/matter_bootloader_internal_series_2.slcp
    id: bootloader
    output: matter_bootloader
post_build:
  path: ../../../postbuild/ws_default_application_bootloader.slpb
