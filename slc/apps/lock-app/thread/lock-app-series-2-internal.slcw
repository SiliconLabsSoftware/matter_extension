label: lock-app-series-2-internal
quality: production
package: matter
description: Internal variant (deprecated placeholder) of Lock over Thread with bootloader (Series 2)
project:
  - path: ./lock-app.slcp
    id: application
    output: lock-app
  - path: ../../bootloaders/bootloader-storage-external-single-series-2/bootloader-storage-external-single-series-2.slcp
    id: bootloader
    output: matter-bootloader
post_build:
  path: ../../../postbuild/ws_default_application_bootloader.slpb
