project_name: window-app-thread
label: Matter Window
description: Matter Window App (Thread)
quality: production
package: matter

sdk_extension:
  - id: matter
    version: "2.7.0"

component:
  - id: device_init
  - id: sl_main
  - id: clock_manager
  - id: matter_buttons
  - id: matter_leds
  - id: matter
  - id: matter_platform_mg
  - id: matter_ble
  - id: matter_thread
  - id: ot_stack_ftd
  - id: rail_util_pti
  - id: matter_crypto
  - id: matter_shell
  - id: matter_gatt_static
  - id: matter_provision_default
  - id: matter_window
  - id: app_common
  - id: matter_access_control
  - id: matter_administrator_commissioning
  - id: matter_basic_information
  - id: matter_descriptor
  - id: matter_fixed_label
  - id: matter_general_commissioning
  - id: matter_general_diagnostics
  - id: matter_group_key_mgmt
  - id: matter_groups
  - id: matter_identify
  - id: matter_localization_configuration
  - id: matter_network_commissioning
  - id: matter_operational_credentials
  - id: matter_ota_requestor
  - id: matter_ota_support
  - id: matter_power_source
  - id: matter_software_diagnostics
  - id: matter_thread_network_diagnostics
  - id: matter_time_format_localization
  - id: matter_user_label
  - id: matter_unit_localization
  - id: matter_wifi_network_diagnostics
  - id: matter_window_covering
  - id: matter_default_lcd_config
  - id: matter_configuration_over_swo
  - id: matter_segger_rtt
  - id: matter_icd_core
  - id: matter_test_event_trigger
  - id: matter_icd_management
  - id: matter_log_uart

config_file:
  - path: ../../../../third_party/matter_sdk/examples/window-app/common/window-app.zap
    file_id: zap_config
  - path: ../../../../provision.mattpconf
    file_id: provision_config

include:
  - path: ../../../../third_party/matter_sdk/examples/window-app/silabs/include
    file_list:
      - path: AppConfig.h
      - path: CHIPProjectConfig.h
      - path: WindowManager.h
      - path: AppTask.h
      - path: AppEvent.h

source:
  - path: ../../../../third_party/matter_sdk/examples/window-app/silabs/src/AppTask.cpp
  - path: ../../../../third_party/matter_sdk/examples/platform/silabs/main.cpp
  - path: ../../../../third_party/matter_sdk/examples/window-app/silabs/src/WindowManager.cpp
  - path: ../../../../third_party/matter_sdk/examples/window-app/silabs/src/DataModelCallbacks.cpp

define:
  - name: CHIP_CRYPTO_PLATFORM
    value: "1"
  - name: _WANT_REENT_SMALL
    value: "1"
  - name: NVM3_DEFAULT_NVM_SIZE
    value: "40960"
  - name: NVM3_DEFAULT_MAX_OBJECT_SIZE
    value: "4092"

configuration:
  - name: SL_BT_CONFIG_USER_ADVERTISERS
    value: 2

readme:
  - path: ./README.md
