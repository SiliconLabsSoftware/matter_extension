workspace_name: matter_thread_soc_zigbee_light_series_3_freertos
label: Matter Thread - SoC Zigbee Light with internal Bootloader FreeRTOS
quality: production
package: matter
description: Demonstrates a sample implementation of a Matter and Zigbee multiprotocol lighting app over Thread with internal bootloader
project:
  - path: ./matter_thread_soc_zigbee_light_freertos.slcp
    id: application
    output: zigbee_light
  - path: ../../bootloaders/bootloader_storage_single_4096k_series_3/matter_bootloader_internal_series_3.slcp
    id: bootloader
    output: matter_bootloader
post_build:
  path: ../../../postbuild/ws_default_application_bootloader.slpb
