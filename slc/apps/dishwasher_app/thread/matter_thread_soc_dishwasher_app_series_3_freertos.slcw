workspace_name: matter_thread_soc_dishwasher_app_series_3_freertos
label: Matter Thread - SoC Dishwasher with internal Bootloader FreeRTOS
quality: production
package: matter
description: Demonstrates a sample implementation of a Matter over Thread dishwasher app with internal bootloader
project:
  - path: ./matter_thread_soc_dishwasher_app_freertos.slcp
    id: application
    output: dishwasher_app
  - path: ../../bootloaders/bootloader_storage_single_4096k_series_3/matter_bootloader_internal_series_3.slcp
    id: bootloader
    output: matter_bootloader
post_build:
  path: ../../../postbuild/ws_default_application_bootloader.slpb
