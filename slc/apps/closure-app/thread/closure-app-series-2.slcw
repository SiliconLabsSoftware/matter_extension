label: closure-app-series-2
quality: production
package: matter
description: Matter solution containing both a Matter bootloader and Closure over Thread Example
project:
  - path: ./closure-app.slcp
    id: application
    output: closure-app-thread
  - path: ../../bootloaders/bootloader-storage-external-single-series-2/bootloader-storage-external-single-series-2.slcp
    id: bootloader
    output: matter-bootloader
post_build:
  path: ../../../postbuild/ws_default_application_bootloader.slpb
