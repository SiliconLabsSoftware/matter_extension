category: Clusters|HVAC
description: >
  Implementation of the Thermostat Server Cluster.
  The user has to enable the Thermostat Server Cluster in the ZCL Advanced Platform (ZAP) tool in order to enable this functionality.
id: matter_thermostat
package: matter
label: Thermostat Server Cluster
quality: production
metadata:
  sbom:
    license: "Apache 2.0"
provides:
  - name: matter_thermostat
source:
  - path: third_party/matter_sdk/src/app/clusters/thermostat-server/PresetStructWithOwnedMembers.cpp
  - path: third_party/matter_sdk/src/app/clusters/thermostat-server/ThermostatCluster.cpp
  - path: third_party/matter_sdk/src/app/clusters/thermostat-server/ThermostatClusterAtomic.cpp
  - path: third_party/matter_sdk/src/app/clusters/thermostat-server/ThermostatClusterEvents.cpp
  - path: third_party/matter_sdk/src/app/clusters/thermostat-server/ThermostatClusterPresets.cpp
  - path: third_party/matter_sdk/src/app/clusters/thermostat-server/ThermostatClusterSuggestions.cpp
  - path: third_party/matter_sdk/src/app/clusters/thermostat-server/ThermostatSuggestionStructWithOwnedMembers.cpp
include:
  - path: third_party/matter_sdk/src/app/clusters/thermostat-server
    file_list:
      - path: PresetStructWithOwnedMembers.h
      - path: ThermostatCluster.h
      - path: ThermostatClusterEvents.h
      - path: ThermostatClusterPresets.h
      - path: ThermostatDelegate.h
      - path: ThermostatSuggestionStructWithOwnedMembers.h
template_contribution:
  - name: component_catalog
    value: matter_thermostat