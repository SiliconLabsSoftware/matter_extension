category: Clusters|Measurement
description: >
  Implementation of the Relative Humidity Measurement Server Cluster.
  The user has to enable the Relative Humidity Measurement Server Cluster in the ZCL Advanced Platform (ZAP) tool in order to enable this functionality.
id: matter_relative_humidity_measurement
package: matter
label: Relative Humidity Measurement Server Cluster
quality: production
metadata:
  sbom:
    license: "Apache 2.0"
provides:
  - name: matter_relative_humidity_measurement
source:
  - path: third_party/matter_sdk/src/app/clusters/relative-humidity-measurement-server/CodegenIntegration.cpp
  - path: third_party/matter_sdk/src/app/clusters/relative-humidity-measurement-server/RelativeHumidityMeasurementCluster.cpp
include:
  - path: third_party/matter_sdk/src/app/clusters/relative-humidity-measurement-server
    file_list:
      - path: CodegenIntegration.h
      - path: RelativeHumidityMeasurementCluster.h
template_contribution:
  - name: component_catalog
    value: matter_relative_humidity_measurement