category: Matter|Examples
package: matter
description: >
  Provides example component for a Platform application. This component should be 
  included in all platform applications to help resolve SLC dependencies. Only applicable to platform applications.
id: matter_platform_template
quality: production
provides:
  - name: matter_platform_template
metadata:
  sbom:
    license: "Apache 2.0"
template_file:
  - path: third_party/matter_sdk/examples/base-platform-app/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/base-platform-app/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/base-platform-app/silabs/src/AppTask.cpp
ui_hints:
  visibility: never