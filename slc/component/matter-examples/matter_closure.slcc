category: Matter|Examples
package: matter
description: >
  Provides example component for a closure application. This component should be 
  included in all closure applications to help resolve SLC dependencies. Only applicable to closure applications.
id: matter_closure
quality: production
provides:
  - name: matter_closure
metadata:
  sbom:
    license: "Apache 2.0"
template_file:
  - path: third_party/matter_sdk/examples/closure-app/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/closure-app/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/closure-app/silabs/include/ClosureManager.h
  - path: third_party/matter_sdk/examples/closure-app/silabs/include/ClosureManagerImpl.h
  - path: third_party/matter_sdk/examples/closure-app/silabs/src/AppTask.cpp

ui_hints:
  visibility: never