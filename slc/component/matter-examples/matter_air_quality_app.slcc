category: Matter|Examples
package: matter
description: >
  Provides example component for a Air Quality application. This component should be 
  included in all Air Quality applications to help resolve SLC dependencies. Only applicable to Air Quality applications.
id: matter_air_quality_app
quality: production
provides:
  - name: matter_air_quality_app
metadata:
  sbom:
    license: "Apache 2.0"
template_file:
  - path: third_party/matter_sdk/examples/air-quality-sensor-app/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/air-quality-sensor-app/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/air-quality-sensor-app/silabs/src/AppTask.cpp
ui_hints:
  visibility: never
