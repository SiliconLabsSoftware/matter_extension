category: Matter|Examples
package: matter
description: >
  Provides example component for a Lighting application. This component should be 
  included in all Lighting applications to help resolve SLC dependencies. Only applicable to Lighting applications.
id: matter_lighting
quality: production
provides:
  - name: matter_lighting

template_file:
  - path: third_party/matter_sdk/examples/lighting-app/silabs/include/AppConfig.h
  - path: third_party/matter_sdk/examples/lighting-app/silabs/include/AppEvent.h
  - path: third_party/matter_sdk/examples/lighting-app/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/lighting-app/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/lighting-app/silabs/include/CHIPProjectConfig.h
  - path: third_party/matter_sdk/examples/lighting-app/silabs/include/LightTypes.h
  - path: third_party/matter_sdk/examples/lighting-app/silabs/src/DataModelCallbacks.cpp
  - path: third_party/matter_sdk/examples/lighting-app/silabs/src/AppTask.cpp

define:
  - name: IS_DEMO_LIGHT
    value: "1"
ui_hints:
  visibility: never
