category: Matter|Examples
package: matter
description: >
  Provides example component for a Light Switch application. This component should be 
  included in all Light Switch applications to help resolve SLC dependencies. Only applicable to Light Switch applications.
id: matter_light_switch
quality: production
provides:
  - name: matter_light_switch
metadata:
  sbom:
    license: "Apache 2.0"
template_file:
  - path: third_party/matter_sdk/examples/light-switch-app/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/light-switch-app/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/light-switch-app/silabs/src/AppTask.cpp
ui_hints:
  visibility: never
