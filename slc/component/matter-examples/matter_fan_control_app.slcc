category: Matter|Examples
package: matter
description: >
  Provides example component for a Fan control application. This component should be 
  included in all Fan control applications to help resolve SLC dependencies. Only applicable to Fan control applications.
id: matter_fan_control_app
quality: production
provides:
  - name: matter_fan_control_app
metadata:
  sbom:
    license: "Apache 2.0"
template_file:
  - path: third_party/matter_sdk/examples/fan-control-app/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/fan-control-app/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/fan-control-app/silabs/src/AppTask.cpp
ui_hints:
  visibility: never
