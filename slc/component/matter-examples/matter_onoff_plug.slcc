category: Matter|Examples
package: matter
description: >
  Provides example component for a On/Off Plug application. This component should be 
  included in all On/Off Plug applications to help resolve SLC dependencies. Only applicable to On/Off Plug applications.
id: matter_onoff_plug
quality: production
provides:
  - name: matter_onoff_plug
metadata:
  sbom:
    license: "Apache 2.0"
template_file:
  - path: third_party/matter_sdk/examples/onoff-plug-app/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/onoff-plug-app/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/onoff-plug-app/silabs/src/AppTask.cpp
ui_hints:
  visibility: never
