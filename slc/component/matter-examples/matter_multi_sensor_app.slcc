category: Matter|Examples
package: matter
description: >
  Provides example component for a Multi-Sensor application. This component should be 
  included in all Multi-Sensor applications to help resolve SLC dependencies. Only applicable to Multi-Sensor applications.
id: matter_multi_sensor_app
quality: production
provides:
  - name: matter_multi_sensor_app
metadata:
  sbom:
    license: "Apache 2.0"
template_file:
  - path: third_party/matter_sdk/examples/multi-sensor-app/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/multi-sensor-app/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/multi-sensor-app/silabs/src/AppTask.cpp
ui_hints:
  visibility: never
