category: Matter|Examples
package: matter
description: >
  Provides example component for a Rangehood application. This component should be 
  included in all rangehood applications to help resolve SLC dependencies. Only applicable to rangehood applications.
id: matter_rangehood
quality: production
provides:
  - name: matter_rangehood
template_file:
  - path: third_party/matter_sdk/examples/rangehood-app/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/rangehood-app/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/rangehood-app/silabs/src/AppTask.cpp
ui_hints:
  visibility: never