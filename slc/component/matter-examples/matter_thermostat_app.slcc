category: Matter|Examples
package: matter
description: >
  Provides example component for a Thermostat application. This component should be 
  included in all Thermostat applications to help resolve SLC dependencies. Only applicable to Thermostat applications.
id: matter_thermostat_app
quality: production
metadata:
  sbom:
    license: "Apache 2.0"

template_file:
  - path: third_party/matter_sdk/examples/thermostat/silabs/include/AppTask.h
  - path: third_party/matter_sdk/examples/thermostat/silabs/include/AppTaskImpl.h
  - path: third_party/matter_sdk/examples/thermostat/silabs/src/AppTask.cpp

provides:
  - name: matter_thermostat_app
define:
  - name: IS_DEMO_THERMOSTAT
    value: "1"
ui_hints:
  visibility: never
