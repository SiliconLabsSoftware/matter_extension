category: Matter|Stack
description: Includes PM25 Zap configuration for Matter applications
id: matter_zap_include
label: Stack
package: matter
provides:
  - name: matter_zap_include
quality: production
metadata:
  sbom:
    license: Zlib
include:
  - path: third_party/matter_sdk/zzz_generated/app-common
    file_list:
      - path: clusters/Pm25ConcentrationMeasurement/AttributeIds.h
      - path: clusters/Pm25ConcentrationMeasurement/Attributes.h
      - path: clusters/Pm25ConcentrationMeasurement/ClusterId.h
      - path: clusters/Pm25ConcentrationMeasurement/CommandIds.h
      - path: clusters/Pm25ConcentrationMeasurement/Commands.h
      - path: clusters/Pm25ConcentrationMeasurement/Enums.h
      - path: clusters/Pm25ConcentrationMeasurement/EnumsCheck.h
      - path: clusters/Pm25ConcentrationMeasurement/EventIds.h
      - path: clusters/Pm25ConcentrationMeasurement/Events.h
      - path: clusters/Pm25ConcentrationMeasurement/Ids.h
      - path: clusters/Pm25ConcentrationMeasurement/Metadata.h
      - path: clusters/Pm25ConcentrationMeasurement/MetadataProvider.h
      - path: clusters/Pm25ConcentrationMeasurement/Structs.h
source:
  - path: third_party/matter_sdk/zzz_generated/app-common/clusters/Pm25ConcentrationMeasurement/Attributes.ipp
  - path: third_party/matter_sdk/zzz_generated/app-common/clusters/Pm25ConcentrationMeasurement/Commands.ipp
  - path: third_party/matter_sdk/zzz_generated/app-common/clusters/Pm25ConcentrationMeasurement/Events.ipp
  - path: third_party/matter_sdk/zzz_generated/app-common/clusters/Pm25ConcentrationMeasurement/Structs.ipp
ui_hints:
    visibility: never
