id: siwx917_ncp_brd4357c
package: matter
label: SiWx917 NCP Component for BRD4357c
description: >
  Adds the config changes required for BRD4357c module board.
category: Matter-WiFi|Platform|Drivers
quality: production
metadata:
  sbom:
    license: Zlib

provides:
  - name: siwx917_ncp_brd4357c

requires:
  - name: siwx917_ncp

define:
  - name: USE_BYPASS_CLOCK
    value: "1"
  - name: SL_SI91X_ACX_MODULE
    value: "1"
