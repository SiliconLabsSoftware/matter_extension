id: matter_aws_lwip_transport
package: matter
description: >
  LwIP altcp-based MQTT/TLS transport for Matter + AWS (host stack). Use with matter_aws
  on SiWx SoC Wi-Fi builds. Mutually exclusive with matter_aws_nwp_transport.
label: Matter AWS LwIP Transport
category: Matter-WiFi|Features
quality: production
metadata:
  sbom:
    license: Zlib

provides:
  - name: matter_aws_lwip_transport
  - name: matter_aws_transport

requires:
  - name: matter_aws

conflicts:
  - name: matter_aws_nwp_transport

config_file:
  - path: slc/config/matter_aws/sl_matter_wifi_config.h
    override:
      component: matter_wifi
      file_id: matter_wifi_config
      vendor: silabs

include:
  - path: third_party/matter_sdk/src/platform/silabs/mqtt/mqtt_transport_interface/include
    file_list:
      - path: altcp.h
      - path: altcp_opt.h
      - path: altcp_priv.h
      - path: altcp_tcp.h
      - path: altcp_tls.h
      - path: altcp_tls_mbedtls_mem.h
      - path: altcp_tls_mbedtls_opts.h
      - path: altcp_tls_mbedtls_structs.h
      - path: tcpbase.h

source:
  - path: third_party/matter_sdk/src/platform/silabs/mqtt/mqtt_transport_interface/lwip/mqtt_transport_altcp.c
  - path: third_party/matter_sdk/src/platform/silabs/mqtt/mqtt_transport_interface/lwip/altcp.c
  - path: third_party/matter_sdk/src/platform/silabs/mqtt/mqtt_transport_interface/lwip/altcp_alloc.c
  - path: third_party/matter_sdk/src/platform/silabs/mqtt/mqtt_transport_interface/lwip/altcp_tcp.c
  - path: third_party/matter_sdk/src/platform/silabs/mqtt/mqtt_transport_interface/lwip/altcp_tls_mbedtls.c
  - path: third_party/matter_sdk/src/platform/silabs/mqtt/mqtt_transport_interface/lwip/altcp_tls_mbedtls_mem.c
